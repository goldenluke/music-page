import { useState } from 'react'
import { Link } from 'react-router-dom'
import { useTranslation } from 'react-i18next'
import { useMutation, useQueryClient } from '@tanstack/react-query'
import axios from 'axios'
import {
  ArrowBigUp,
  ArrowBigDown,
  MessageSquare,
  Share2,
  Bookmark,
  ExternalLink,
  MoreHorizontal,
  User as UserIcon,
  Play
} from 'lucide-react'
import Comments from './Comments'

export default function MusicCard({ post, user }) {

  const { t } = useTranslation()
  const [showComments, setShowComments] = useState(false)
  const queryClient = useQueryClient()

  const voteMutation = useMutation({
    mutationFn: () => api.post(`/posts/${post?.id}/upvote`),
                                   onSuccess: () => queryClient.invalidateQueries(['posts']),
                                   onError: (err) => {
                                     if (err.response?.status === 401)
                                       alert(t('login_to_vote', 'Faça login para votar'))
                                   }
  })

  const saveMutation = useMutation({
    mutationFn: () => api.post(`/posts/${post?.id}/save`),
                                   onSuccess: () => {
                                     queryClient.invalidateQueries(['posts'])
                                     queryClient.invalidateQueries(['saved-posts'])
                                   },
                                   onError: (err) => {
                                     if (err.response?.status === 401)
                                       alert(t('login_to_save', 'Faça login para salvar'))
                                   }
  })

  if (!post) return null

    return (

      <div className="group relative bg-white/90 dark:bg-[#0f1115] border border-white/20 rounded-[32px] flex flex-col transition-all duration-300 hover:border-green-500/30 hover:shadow-[0_0_40px_-15px_rgba(0,200,83,0.4)] overflow-hidden">

      <div className="flex">

      {/* COLUNA DE VOTOS */}

      <div className="w-12 md:w-14 flex flex-col items-center py-6 bg-black/20 rounded-l-[32px] border-r border-white/20 shrink-0">

      <button
      onClick={() => voteMutation.mutate()}
      className={`p-1 transition-all transform active:scale-150 ${post.voted ? 'text-green-500' : 'text-slate-500 hover:text-green-400'}`}
      >

      <ArrowBigUp
      size={32}
      fill={post.voted ? "currentColor" : "none"}
      strokeWidth={post.voted ? 2.5 : 2}
      />

      </button>

      <span className={`text-sm font-black my-1 ${post.voted ? 'text-green-500' : 'text-slate-200'}`}>
      {post.score || 0}
      </span>

      <button className="p-1 text-slate-500 hover:text-red-500">
      <ArrowBigDown size={32}/>
      </button>

      </div>

      {/* CONTEÚDO */}

      <div className="flex-1 p-5 md:p-7 min-w-0">

      {/* HEADER */}

      <div className="flex justify-between items-start mb-4">

      <div className="flex items-center gap-3">

      <Link
      to={`/profile/${post.author_username}`}
      className="flex items-center gap-2"
      >

      <div className="w-6 h-6 rounded-lg bg-green-600 flex items-center justify-center text-[10px] font-black text-white">

      {post.author_username?.[0]?.toUpperCase() || <UserIcon size={12}/>}

      </div>

      <span className="text-[11px] font-bold text-slate-500 uppercase tracking-widest">
      u/{post.author_username || 'anon'}
      </span>

      </Link>

      {post.genre_name && (

        <span className="bg-green-600/10 text-green-500 px-2.5 py-0.5 rounded-full text-[9px] font-black uppercase border border-green-500/10">

        {post.genre_name}

        </span>

      )}

      </div>

      <button className="text-slate-600 hover:text-white">
      <MoreHorizontal size={20}/>
      </button>

      </div>

      {/* TÍTULO */}

      <h3 className="text-xl md:text-2xl font-black text-white mb-1 leading-tight group-hover:text-green-400 transition-colors">
      {post.title}
      </h3>

      {post.artist && (

        <Link
        to={`/artist/${post.artist.slug}`}
        className="text-xs text-green-500 font-bold mb-3 block hover:underline"
        >

        {post.artist.name}

        </Link>

      )}

      {/* TEXTO */}

      {post.content && (

        <p className="text-slate-400 text-sm mb-5 italic">

        {post.content}

        </p>

      )}

      {/* IMAGEM */}

      {post.image && (

        <div className="mb-6 rounded-2xl overflow-hidden border border-white/20">

        <img
        src={post.image}
        alt={post.title}
        className="w-full max-h-[500px] object-cover"
        />

        </div>

      )}

      {/* PLAYER / LINK */}

      <div className="relative mb-8">

      {post.embed_url ? (

        <div className="rounded-2xl overflow-hidden border border-white/10">

        <iframe
        src={post.embed_url}
        className="w-full h-[200px]"
        allow="autoplay; encrypted-media"
        loading="lazy"
        title={post.title}
        />

        </div>

      ) : (

        <a
        href={post.url}
        target="_blank"
        rel="noreferrer"
        className="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/20 hover:bg-white/10 transition-all"
        >

        <div className="flex items-center gap-3 truncate">

        <div className="w-8 h-8 bg-green-600/20 rounded-lg flex items-center justify-center text-green-500">

        <Play size={14} fill="currentColor"/>

        </div>

        <span className="text-sm text-slate-500 italic truncate">

        {post.url}

        </span>

        </div>

        <ExternalLink size={16}/>

        </a>

      )}

      </div>

      {/* AÇÕES */}

      <div className="flex flex-wrap gap-3 items-center pt-2 border-t border-white/20">

      <button
      onClick={() => setShowComments(!showComments)}
      className={`flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] px-3 py-2 rounded-xl ${showComments ? 'bg-green-500/10 text-green-500' : 'text-slate-500 hover:bg-white/5 hover:text-white'}`}
      >

      <MessageSquare size={16}/>
      {t('discussion')}

      </button>

      <button
      onClick={() => saveMutation.mutate()}
      className={`flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] px-3 py-2 rounded-xl ${post.is_saved ? 'bg-yellow-500/10 text-yellow-500' : 'text-slate-500 hover:bg-white/5 hover:text-white'}`}
      >

      <Bookmark size={16} fill={post.is_saved ? "currentColor" : "none"}/>

      {post.is_saved ? t('saved') : t('save')}

      </button>

      <button className="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 hover:bg-white/5 hover:text-white px-3 py-2 rounded-xl">

      <Share2 size={16}/>
      {t('share')}

      </button>

      </div>

      {/* COMENTÁRIOS */}

      {showComments && (

        <div className="mt-6">

        <Comments postId={post.id} user={user}/>

        </div>

      )}

      </div>
      </div>
      </div>
    )
}
